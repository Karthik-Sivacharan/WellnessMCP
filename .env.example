# WellnessMCP Configuration
# Copy to .env and fill in your values

# === Provider OAuth Client IDs ===
# Register your own apps at each provider's developer portal

# Oura Ring (https://cloud.ouraring.com/v2/docs)
OURA_CLIENT_ID=
OURA_CLIENT_SECRET=

# WHOOP (https://developer.whoop.com/)
WHOOP_CLIENT_ID=
WHOOP_CLIENT_SECRET=

# Garmin Connect (https://developer.garmin.com/)
GARMIN_CONSUMER_KEY=
GARMIN_CONSUMER_SECRET=

# Fitbit (https://dev.fitbit.com/)
FITBIT_CLIENT_ID=
FITBIT_CLIENT_SECRET=

# Dexcom (https://developer.dexcom.com/)
DEXCOM_CLIENT_ID=
DEXCOM_CLIENT_SECRET=

# === Apple Health ===
# Path to your Apple Health export folder
APPLE_HEALTH_EXPORT_PATH=

# === Local Settings ===
# OAuth redirect port (default: 9876)
OAUTH_REDIRECT_PORT=9876

# Data retention days (default: 90)
DATA_RETENTION_DAYS=90

# Database path (default: ~/.wellness-mcp/data.db)
DB_PATH=
