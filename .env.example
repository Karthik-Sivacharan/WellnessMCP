# WellnessMCP Configuration (Stateless Proxy)

# Port for the HTTP server (default: 3456)
WELLNESS_MCP_INGEST_PORT=3456

# API key for authenticating requests from the iOS app (recommended)
WELLNESS_MCP_INGEST_KEY=your-secret-key-here

# Optional: Default Anthropic API key (users can also send their own per-request)
ANTHROPIC_API_KEY=
